# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/chinamed_connect

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM="ChinaMed Connect <noreply@chinamedconnect.com>"
ADMIN_EMAIL=admin@chinamedconnect.com

# Admin Panel
ADMIN_URL=http://localhost:3001

# JWT Secret (for admin authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Optional: AWS S3 for file storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stripe Payment Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Notes:
# 1. For Gmail SMTP_PASS: Generate an "App Password" from Google Account settings
# 2. For Stripe keys: Use test keys (sk_test_...) for development
# 3. For production: Use live keys (sk_live_...) and update FRONTEND_URL
# 4. Never commit this file to Git! Keep it in .gitignore
